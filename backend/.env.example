# ========== Obligatoire ==========
# PostgreSQL (Supabase, Neon ou autre). En production, obligatoire.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# En production : secret fort (min. 32 caractères aléatoires). Jamais le défaut dev.
JWT_SECRET="votre-secret-jwt-tres-long-et-aleatoire"

# URL du frontend (Vercel). Utilisée pour CORS et liens d’activation.
FRONTEND_URL="https://votre-app.vercel.app"

# ========== Optionnel / fonctionnalités ==========
# Indicatif pays pour les numéros : 33 (France), 225 (Côte d'Ivoire)
COUNTRY_CODE="225"

# WhatsApp Cloud API — si vides : mode démo (OTP affiché à l’écran)
WHATSAPP_INVITATION_TEMPLATE_NAME="invitation_activation"
WHATSAPP_INVITATION_TEMPLATE_LANGUAGE="fr"
WHATSAPP_INVITATION_TEMPLATE_HAS_LINK=true
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# SMS (ex. Wirepick)
WIREPICK_API_URL=""
WIREPICK_CLIENT=""
WIREPICK_PASSWORD=""
WIREPICK_FROM=""

# CinetPay (paiements)
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
# URL publique du backend pour le webhook (ex: https://votre-backend.onrender.com)
CINETPAY_NOTIFY_URL=""
CINETPAY_CURRENCY="XOF"

# Port (Render / hébergeur le définit souvent)
PORT=3000

# Environnement (production = CORS strict, validation JWT_SECRET)
NODE_ENV=development
